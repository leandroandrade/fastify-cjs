{
  "name": "fastify-cjs",
  "version": "1.2.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "test": "node --env-file=.env.test --test --test-concurrency=1 ./tests/**/*.test.js",
    "test:only": "node --env-file=.env.test --test --test-only ./tests/**/*.test.js",
    "test:single": "node --env-file=.env.test --test --test-concurrency=1",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --env-file=.env.test --test --test-concurrency=1 ./tests/**/*.test.js",
    "test:report": "c8 --reporter=html node --env-file=.env.test --test --test-concurrency=1 ./tests/**/*.test.js",
    "dev": "node --env-file=.env --watch-path=./src src/server.js",
    "start": "node src/server.js",
    "lint": "eslint",
    "lint:fix": "npm run lint -- --fix"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leandroandrade/fastify-cjs.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/leandroandrade/fastify-cjs/issues"
  },
  "homepage": "https://github.com/leandroandrade/fastify-cjs#readme",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/env": "^6.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "close-with-grace": "^2.5.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^10.2.1",
    "neostandard": "^0.13.0"
  }
}
